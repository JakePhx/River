// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  username     String  @unique
  name         String?
  passwordHash String
  role         Role    @default(USER)
  isPrivate    Boolean @default(false)
  isActive     Boolean @default(true)

  postCount      Int @default(0)
  followersCount Int @default(0)
  followingCount Int @default(0)

  followers Follow[] @relation("followers")
  following Follow[] @relation("following")

  blockedUsers Block[] @relation("blocker")
  blockedBy    Block[] @relation("blocked")

  sentRequest     FollowRequest[] @relation("requester")
  receivedRequest FollowRequest[] @relation("requested")

  posts    Post[]
  comments Comment[]

  profile Profile?

  hasUnreadNotifications Boolean @default(false)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]

  chatThreadsLow   ChatThread[]               @relation("ChatUserLow")
  chatThreadsHigh  ChatThread[]               @relation("ChatUserHigh")
  chatThreadsInit  ChatThread[]               @relation("ChatInitiatedBy")
  chatMessages          ChatMessage[]
  chatReadStates        ChatParticipantReadState[]
  chatLastMessageSender ChatThread[] @relation("ChatLastMessageSender")

  @@index([email])
  @@index([username])
}

model Profile {
  id        String    @id @default(uuid())
  title     String?
  company   String?
  bio       String?
  gender    Gender?
  website   String?
  birthDate DateTime?
  location  String?
  avatarUrl String?
  coverUrl  String?
  contact   String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Follow {
  followerId  String
  followingId String

  follower  User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([followerId, followingId]) // Prevent duplicate follows
  @@index([followingId])
  @@index([followerId])
}

model FollowRequest {
  requesterId String
  requestedId String

  requester User @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  requested User @relation("requested", fields: [requestedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([requesterId, requestedId])
  @@index([requestedId])
}

model Block {
  blockerId String
  blockedId String

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

enum PostAttachmentKind {
  IMAGE
  VIDEO
}

model Post {
  id       String @id @default(uuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments    Comment[]
  attachments PostAttachment[]

  @@index([authorId, createdAt])
}

model PostAttachment {
  id          String             @id @default(uuid())
  postId      String
  post        Post               @relation(fields: [postId], references: [id], onDelete: Cascade)
  url         String
  contentType String
  byteSize    Int
  kind        PostAttachmentKind
  position    Int                @default(0)

  createdAt DateTime @default(now())

  @@index([postId, position])
}

model Comment {
  id       String @id
  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([parentId])
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  payload Json
  isRead  Boolean @default(false)

  eventId     String
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ChatThreadStatus {
  PENDING
  ACTIVE
  REJECTED
}

model ChatThread {
  id              String           @id @default(uuid())
  userIdLow       String
  userIdHigh      String
  status          ChatThreadStatus
  initiatedById   String
  lastMessageAt       DateTime?
  lastMessageText     String?          @db.VarChar(512)
  lastMessageSenderId String?

  userLow           User  @relation("ChatUserLow", fields: [userIdLow], references: [id], onDelete: Cascade)
  userHigh          User  @relation("ChatUserHigh", fields: [userIdHigh], references: [id], onDelete: Cascade)
  initiatedBy       User  @relation("ChatInitiatedBy", fields: [initiatedById], references: [id], onDelete: Cascade)
  lastMessageSender User? @relation("ChatLastMessageSender", fields: [lastMessageSenderId], references: [id], onDelete: SetNull)

  messages   ChatMessage[]
  readStates ChatParticipantReadState[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userIdLow, userIdHigh])
  @@index([userIdLow])
  @@index([userIdHigh])
  @@index([lastMessageAt])
}

model ChatParticipantReadState {
  threadId              String
  userId                String
  lastReadAt            DateTime?
  /** Recipient opened a pending message request (clears request badge). */
  pendingRequestSeenAt DateTime?

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
}

model ChatMessage {
  id        String    @id @default(uuid())
  threadId  String
  senderId  String
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  replyToId String?
  replyTo   ChatMessage? @relation("ChatMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[] @relation("ChatMessageReply")

  thread     ChatThread               @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender     User                     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  attachment ChatMessageAttachment?

  @@index([threadId, createdAt])
  @@index([replyToId])
}

model ChatMessageAttachment {
  id          String @id @default(uuid())
  messageId   String @unique
  message     ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url         String
  contentType String
  byteSize    Int
  fileName    String?

  @@index([messageId])
}
