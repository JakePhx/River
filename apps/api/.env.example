# Copy to .env and adjust. DATABASE_URL uses 127.0.0.1 so Prisma CLI works on the host
# while Postgres is published from Docker (see root docker-compose.yml). The `api` service
# overrides DATABASE_URL to use hostname `db` inside the Compose network.

ENVIRONMENT=development
DATABASE_URL=postgresql://admin:admin123@127.0.0.1:5432/linktree
JWT_ACCESS_SECRET=change-me
KAFKAJS_NO_PARTITIONER_WARNING=1
KAFKA_BROKERS=127.0.0.1:9092
CLIENT_URL=http://localhost:5173
