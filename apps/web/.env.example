# Dev: use /api so the browser hits the Vite dev server and it proxies to the API (see vite.config.ts).
# Never set PUBLIC_API_BASE_URL=http://api:3000 — hostnames like `api` only work between Docker containers, not in the browser.
# Docker Compose sets API_PROXY_TARGET=http://api:3000 for the Vite proxy only (not a PUBLIC_ var).
PUBLIC_API_BASE_URL=/api

# Point the browser at LocalStack directly (port 4566 must be published — see docker-compose).
# Do NOT use same-origin `/s3` here: the Vite proxy rewrites the path, but SigV4 is computed for the
# original path (/s3/bucket/...), so LocalStack sees a different path and rejects the request; the SDK
# then often surfaces that as a DOMParser / deserialization error.
# From another machine on your LAN, use http://<host-ip>:4566 instead of 127.0.0.1.
PUBLIC_S3_ENDPOINT=http://127.0.0.1:4566
PUBLIC_S3_ASSET_BASE_URL=http://127.0.0.1:4566
# Optional: if you keep PUBLIC_S3_* as /s3 in dev, the client auto-uses 127.0.0.1:4566 unless you set:
# PUBLIC_S3_DIRECT_URL=http://192.168.x.x:4566
PUBLIC_S3_REGION=us-east-1
PUBLIC_S3_BUCKET=avatars
PUBLIC_S3_ACCESS_KEY_ID=test
PUBLIC_S3_SECRET_ACCESS_KEY=test
